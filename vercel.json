{
  "functions": {
    "app/api/**": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/billing-alerts",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/reminders",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/call-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/omni-daily-briefing",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/omni-unanswered-summary",
      "schedule": "0 23 * * *"
    }
  ]
}
